# Hypercare Automation — environment variables
# Copy to .env and fill in every value.
#   cp env.example .env
# Never commit .env to git.

# Which client to run — must match config/clients/<id>.json
HYPERCARE_CLIENT=myclient

# GCP service-account key (drop the file in the project root, use just the filename)
GOOGLE_APPLICATION_CREDENTIALS=your-service-account-key.json

# Unified DB — read-only credentials
UNIFIED_DB_HOST=
UNIFIED_DB_USER=
UNIFIED_DB_PASSWORD=

# Tao DB — read-only credentials
TAO_DB_HOST=
TAO_DB_USER=
TAO_DB_PASSWORD=

# Mojo — refresh the token from mojopro.joveo.com DevTools every ~2 h
# Important: must be a mojopro token (productId=mojopro), NOT a TALENT_ENGAGE token
MOJO_ACCESS_TOKEN=
MOJO_EMAIL=your.name@joveo.com

# ── Optional overrides ────────────────────────────────────────────────────────
# HYPERCARE_JOB_DATE=YYYY-MM-DD     # override today for Job Ingestion
# HYPERCARE_REPORT_DATE=YYYY-MM-DD  # override yesterday for Mojo Apply / Funnel Tracking
