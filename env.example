# =============================================================================
# Hypercare Automation — environment variables template
# Copy this file to .env and fill in the real values.
# NEVER commit .env to git.
# =============================================================================


# --- Active client -----------------------------------------------------------
# Matches a file in config/clients/<id>.json
# Non-secret client settings (sheet ID, go-live date, enabled trackers, DB IDs, Mojo IDs)
# live in that JSON.
HYPERCARE_CLIENT=ashleyfurniture

# Direct sheet override (skips HYPERCARE_CLIENT lookup if set)
# GOOGLE_SHEETS_SPREADSHEET_ID=


# --- Google Sheets service account ------------------------------------------
GOOGLE_APPLICATION_CREDENTIALS=/absolute/path/to/hypercare-automation-*.json


# --- PostgreSQL (shared across clients; read-only access enforced in code) ---
# Unified datastore
UNIFIED_DB_HOST=
UNIFIED_DB_PORT=5432
UNIFIED_DB_NAME=unified_datastore
UNIFIED_DB_USER=
UNIFIED_DB_PASSWORD=

# Tao DB
TAO_DB_HOST=
TAO_DB_PORT=5432
TAO_DB_NAME=tao_db
TAO_DB_USER=
TAO_DB_PASSWORD=


# --- Mojo API ----------------------------------------------------------------
# Base URL and path are common; account/agency/client IDs come from client JSON.
MOJO_BASE_URL=https://mojopro.joveo.com
# Short-lived Cognito ID token — refresh from browser dev tools when expired (~2h).
MOJO_ACCESS_TOKEN=
# User identity headers
MOJO_EMAIL=
MOJO_USERNAME=
# Optional
# MOJO_USER_AGENT=hypercare-automation/0.1 (+python-requests)


# --- ATS website open-jobs ---------------------------------------------------
# ATS_PROVIDER and ATS_CLIENT are normally read from config/clients/<id>.json
# automatically. Set them here only if you want to override.
# ATS_PROVIDER=ukg
# ATS_CLIENT=ashleyfurniture

# UKG — no credentials needed; public job board API is unauthenticated.
# Only the URL + request body in config/ats/ukg/<client>.json are required.
# UKG_HTTP_TIMEOUT=20  # optional, default 20s


# --- Date overrides (optional) -----------------------------------------------
# HYPERCARE_JOB_DATE=YYYY-MM-DD   # overrides today for Job Ingestion queries
# HYPERCARE_REPORT_DATE=YYYY-MM-DD  # overrides yesterday for Mojo Apply / Funnel queries
